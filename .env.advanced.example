# ThreadClaw Advanced Configuration
# These settings are optional. Most users don't need to change them.
# Copy the settings you need into your .env file.

# ── Source: Obsidian (optional) ──
OBSIDIAN_ENABLED=false
# Absolute path to your Obsidian vault root
OBSIDIAN_VAULT_PATH=
# Collection name for ingested Obsidian notes
OBSIDIAN_COLLECTION=obsidian

# ── Source: Google Drive (optional) ──
# 1. Create OAuth client at console.cloud.google.com > APIs > Credentials
# 2. Enable the Google Drive API
# 3. Set redirect URI to http://localhost:18801/oauth2callback
# 4. Authenticate via TUI: Sources > Configure Google Drive > Connect
GDRIVE_ENABLED=false
# OAuth 2.0 client ID from Google Cloud Console
GDRIVE_CLIENT_ID=
# OAuth 2.0 client secret
GDRIVE_CLIENT_SECRET=
# Sync interval in seconds
GDRIVE_SYNC_INTERVAL=300
# Comma-separated folder IDs to sync (empty = all)
GDRIVE_FOLDERS=
# Max file size in bytes (50 MB default)
GDRIVE_MAX_FILE_SIZE=52428800

# ── Source: Microsoft OneDrive (optional) ──
# Option 1: Local sync folder (auto-detected if OneDrive desktop app installed)
ONEDRIVE_ENABLED=false
# Path to the local OneDrive sync folder (auto-detected if blank)
ONEDRIVE_LOCAL_PATH=
# Option 2: Cloud API (Azure AD OAuth)
# 1. Register app at portal.azure.com > App registrations
# 2. Add redirect URI: http://localhost:18802/oauth2callback
# 3. Add API permission: Files.Read.All
# Azure AD application (client) ID
ONEDRIVE_CLIENT_ID=
# Azure AD client secret
ONEDRIVE_CLIENT_SECRET=
# Sync interval in seconds
ONEDRIVE_SYNC_INTERVAL=300
# Comma-separated folder paths to sync (empty = all)
ONEDRIVE_FOLDERS=
# Max file size in bytes (50 MB default)
ONEDRIVE_MAX_FILE_SIZE=52428800

# ── Source: Notion (optional, coming soon) ──
NOTION_ENABLED=false
# Internal integration token — create at https://www.notion.so/my-integrations
NOTION_API_KEY=
# Sync interval in seconds
NOTION_SYNC_INTERVAL=600
# Comma-separated Notion database IDs to ingest
NOTION_DATABASES=
# Whether to recursively include child pages
NOTION_INCLUDE_SUBPAGES=true

# ── Source: Apple Notes (optional, macOS only, coming soon) ──
APPLE_NOTES_ENABLED=false
# Sync interval in seconds
APPLE_NOTES_SYNC_INTERVAL=600
# Comma-separated folder names to import (empty = all)
APPLE_NOTES_FOLDERS=

# ── Audio Transcription (optional, requires Whisper) ──
# pip install openai-whisper
AUDIO_TRANSCRIPTION_ENABLED=false
WHISPER_MODEL=base

# ── Global Source Settings ──
# Temporary directory for downloaded/converted files before ingestion
SOURCE_STAGING_DIR=~/.threadclaw/staging
# Default max file size in bytes for all source adapters (50 MB)
SOURCE_DEFAULT_MAX_FILE_SIZE=52428800

# ── Relations / Evidence Graph (optional) ──
# Entity extraction and awareness from ingested documents.
THREADCLAW_RELATIONS_ENABLED=false
# Path to the SQLite graph database (default: ~/.threadclaw/data/graph.db)
THREADCLAW_RELATIONS_GRAPH_DB_PATH=

# ── Memory Engine: Relations (optional, for OpenClaw plugin) ──
THREADCLAW_MEMORY_RELATIONS_ENABLED=false
# Path to the memory engine's graph database
THREADCLAW_MEMORY_RELATIONS_GRAPH_DB_PATH=
# Extraction mode: "fast" (regex only), "smart" (LLM-assisted), "off"
THREADCLAW_MEMORY_RELATIONS_EXTRACTION_MODE=smart
# Minimum entity mention count before creating a relation
THREADCLAW_MEMORY_RELATIONS_MIN_MENTIONS=2
# Days before an un-reinforced relation is considered stale
THREADCLAW_MEMORY_RELATIONS_STALE_DAYS=30
# Awareness: surface related notes/entities in query context
THREADCLAW_MEMORY_RELATIONS_AWARENESS_ENABLED=false
# Max related notes to surface per query
THREADCLAW_MEMORY_RELATIONS_AWARENESS_MAX_NOTES=3
# Max tokens for awareness context injection
THREADCLAW_MEMORY_RELATIONS_AWARENESS_MAX_TOKENS=100
# Surface full documents (not just excerpts) in awareness
THREADCLAW_MEMORY_RELATIONS_AWARENESS_DOC_SURFACING=false
# Extract factual claims from ingested documents
THREADCLAW_MEMORY_RELATIONS_CLAIM_EXTRACTION_ENABLED=false
# Extract claims from user messages (conversation memory)
THREADCLAW_MEMORY_RELATIONS_USER_CLAIM_EXTRACTION_ENABLED=false
# Context tier: "minimal", "standard", "full" — controls how much graph context is injected
THREADCLAW_MEMORY_RELATIONS_CONTEXT_TIER=standard
# Track extraction attempts to avoid re-processing unchanged documents
THREADCLAW_MEMORY_RELATIONS_ATTEMPT_TRACKING_ENABLED=false
# Days between relation decay sweeps (removes stale relations)
THREADCLAW_MEMORY_RELATIONS_DECAY_INTERVAL_DAYS=90

# ── Memory Engine: Deep Extraction (optional, requires LLM API) ──
# Uses an external LLM for higher-quality entity/relation extraction
THREADCLAW_MEMORY_RELATIONS_DEEP_EXTRACTION_ENABLED=false
# Model name for deep extraction (e.g., "gpt-4o", "claude-sonnet-4-20250514")
THREADCLAW_MEMORY_RELATIONS_DEEP_EXTRACTION_MODEL=
# Provider: "openai", "anthropic", "openrouter", etc.
THREADCLAW_MEMORY_RELATIONS_DEEP_EXTRACTION_PROVIDER=
# API key for the deep extraction LLM provider
THREADCLAW_MEMORY_RELATIONS_DEEP_EXTRACTION_API_KEY=
# Base URL override for the deep extraction provider (e.g., custom OpenAI-compatible endpoint)
THREADCLAW_MEMORY_RELATIONS_DEEP_EXTRACTION_BASE_URL=

# ── Memory Engine: Summary (optional) ──
# Model and provider for generating memory summaries
THREADCLAW_MEMORY_SUMMARY_MODEL=
THREADCLAW_MEMORY_SUMMARY_PROVIDER=

# ── Memory Engine: Tuning ──
# THREADCLAW_MEMORY_COMPACTION_INTERVAL_MS=3600000
# THREADCLAW_MEMORY_COMPACTION_THRESHOLD=100
# THREADCLAW_MEMORY_MAX_CONTEXT_TOKENS=4000
# THREADCLAW_MEMORY_DECAY_ENABLED=false
# THREADCLAW_MEMORY_DECAY_HALF_LIFE_DAYS=30

# ── Model Server ──
# URL for the Python model server (embedding + reranking)
# THREADCLAW_MODEL_SERVER_URL=http://127.0.0.1:8012
# Device for Docling document conversion: "cpu", "cuda", "mps"
# DOCLING_DEVICE=cpu
# Allow models that require trust_remote_code (executes arbitrary code from HuggingFace)
# TRUST_REMOTE_CODE=false

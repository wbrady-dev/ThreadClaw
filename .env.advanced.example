# ClawCore Advanced Configuration
# These settings are optional. Most users don't need to change them.
# Copy the settings you need into your .env file.

# ── Source: Obsidian (optional) ──
OBSIDIAN_ENABLED=false
OBSIDIAN_VAULT_PATH=
OBSIDIAN_COLLECTION=obsidian

# ── Source: Google Drive (optional) ──
# 1. Create OAuth client at console.cloud.google.com > APIs > Credentials
# 2. Enable the Google Drive API
# 3. Set redirect URI to http://localhost:18801/oauth2callback
# 4. Authenticate via TUI: Sources > Configure Google Drive > Connect
GDRIVE_ENABLED=false
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_SYNC_INTERVAL=300
GDRIVE_FOLDERS=
GDRIVE_MAX_FILE_SIZE=52428800

# ── Source: Microsoft OneDrive (optional) ──
# Option 1: Local sync folder (auto-detected if OneDrive desktop app installed)
ONEDRIVE_ENABLED=false
ONEDRIVE_LOCAL_PATH=
# Option 2: Cloud API (Azure AD OAuth)
# 1. Register app at portal.azure.com > App registrations
# 2. Add redirect URI: http://localhost:18802/oauth2callback
# 3. Add API permission: Files.Read.All
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_SYNC_INTERVAL=300
ONEDRIVE_FOLDERS=
ONEDRIVE_MAX_FILE_SIZE=52428800

# ── Source: Notion (optional, coming soon) ──
NOTION_ENABLED=false
NOTION_SYNC_INTERVAL=600
NOTION_DATABASES=
NOTION_INCLUDE_SUBPAGES=true

# ── Source: Apple Notes (optional, macOS only, coming soon) ──
APPLE_NOTES_ENABLED=false
APPLE_NOTES_SYNC_INTERVAL=600
APPLE_NOTES_FOLDERS=

# ── Audio Transcription (optional, requires Whisper) ──
# pip install openai-whisper
AUDIO_TRANSCRIPTION_ENABLED=false
WHISPER_MODEL=base

# ── Global Source Settings ──
SOURCE_STAGING_DIR=~/.clawcore/staging
SOURCE_DEFAULT_MAX_FILE_SIZE=52428800

# ── Relations / Evidence Graph (optional) ──
# Entity extraction and awareness from ingested documents.
CLAWCORE_RELATIONS_ENABLED=false
CLAWCORE_RELATIONS_GRAPH_DB_PATH=

# ── Memory Engine: Relations (optional, for OpenClaw plugin) ──
CLAWCORE_MEMORY_RELATIONS_ENABLED=false
CLAWCORE_MEMORY_RELATIONS_GRAPH_DB_PATH=
CLAWCORE_MEMORY_RELATIONS_MIN_MENTIONS=2
CLAWCORE_MEMORY_RELATIONS_STALE_DAYS=30
CLAWCORE_MEMORY_RELATIONS_AWARENESS_ENABLED=false
CLAWCORE_MEMORY_RELATIONS_AWARENESS_MAX_NOTES=3
CLAWCORE_MEMORY_RELATIONS_AWARENESS_MAX_TOKENS=100
CLAWCORE_MEMORY_RELATIONS_AWARENESS_DOC_SURFACING=false
CLAWCORE_MEMORY_RELATIONS_CLAIM_EXTRACTION_ENABLED=false
CLAWCORE_MEMORY_RELATIONS_USER_CLAIM_EXTRACTION_ENABLED=false
CLAWCORE_MEMORY_RELATIONS_CONTEXT_TIER=standard
CLAWCORE_MEMORY_RELATIONS_ATTEMPT_TRACKING_ENABLED=false
CLAWCORE_MEMORY_RELATIONS_DECAY_INTERVAL_DAYS=90
CLAWCORE_MEMORY_RELATIONS_DEEP_EXTRACTION_ENABLED=false
CLAWCORE_MEMORY_RELATIONS_DEEP_EXTRACTION_MODEL=
CLAWCORE_MEMORY_RELATIONS_DEEP_EXTRACTION_PROVIDER=

# ThreadClaw RAG Configuration
THREADCLAW_PORT=18800
THREADCLAW_HOST=127.0.0.1
THREADCLAW_DATA_DIR=./data

# Model Server (Python)
MODEL_SERVER_HOST=127.0.0.1
# MODEL_SERVER_PORT=8012
# VRAM_FRACTION=0.90
# SPACY_NER_MODEL=en_core_web_sm
# MAX_PARSE_SIZE_MB=100
# PARSE_ALLOWED_DIRS=

# Embedding Model
# Local: points to the Python model server
# Cloud: points to OpenAI/Voyage/Cohere API (set API key below)
EMBEDDING_URL=http://127.0.0.1:8012/v1
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSIONS=1024
EMBEDDING_API_KEY=
# Note: Some models (e.g., Nomic, Jina, Stella, GTE-Qwen, Nemotron) require
# trust_remote_code=true in server/config.json. This executes ARBITRARY code from
# the model's HuggingFace repo. Only enable for models you trust. Default: false.

# Reranking Model
# Local: points to the Python model server
# Cloud: points to Cohere/Jina reranking API (set API key below)
RERANKER_URL=http://127.0.0.1:8012
RERANKER_MODEL=
RERANKER_API_KEY=

# ── Search Tuning ──
# Rerank: minimum score to keep a result (0.0 = keep all, 0.1-0.3 = filter weak)
RERANK_SCORE_THRESHOLD=0.0
# Rerank: how many candidates to send to cross-encoder (1-100)
RERANK_TOP_K=20
# Rerank: auto-skip when top result clearly dominates (saves 50-200ms)
RERANK_SMART_SKIP=true
# Rerank: disable cross-encoder entirely (faster, less accurate)
RERANK_DISABLED=false
# Embedding: max L2 distance to consider a match (lower = stricter)
EMBEDDING_SIMILARITY_THRESHOLD=1.05
# Embedding: prefix mode (auto, always, never)
EMBEDDING_PREFIX_MODE=auto
# Embedding: batch size for bulk ingestion
EMBEDDING_BATCH_SIZE=32

# Query Expansion (optional — local or cloud chat LLM)
QUERY_EXPANSION_ENABLED=false
QUERY_EXPANSION_URL=http://127.0.0.1:1234/v1
QUERY_EXPANSION_MODEL=
QUERY_EXPANSION_API_KEY=

# ── Query Pipeline ──
# Cache: max entries and TTL for query result caching
# QUERY_CACHE_MAX_ENTRIES=50
# QUERY_CACHE_TTL_MS=300000
# Hybrid search: RRF fusion constant and per-signal weights
# HYBRID_RRF_K=60
# HYBRID_VECTOR_WEIGHT=1.0
# HYBRID_BM25_WEIGHT=1.0
# Max query length in characters (longer queries are truncated)
# QUERY_MAX_LENGTH=2000
# Low confidence threshold — results below this score trigger a warning
# QUERY_LOW_CONFIDENCE_THRESHOLD=0.3
# Reranker network timeout (ms)
# RERANK_TIMEOUT_MS=30000

# ── Extraction Pipeline ──
# Max file size accepted for ingestion (MB)
# INGEST_MAX_FILE_SIZE_MB=100
# Deduplication: cosine similarity threshold for near-duplicate detection
# DEDUP_SIMILARITY_THRESHOLD=0.95
# Embedding concurrency, retries, and timeout
# EMBEDDING_MAX_CONCURRENT=2
# EMBEDDING_MAX_RETRIES=3
# EMBEDDING_TIMEOUT_MS=30000
# Circuit breaker cooldown after repeated embedding failures (ms)
# EMBEDDING_CIRCUIT_COOLDOWN_MS=30000
# OCR language (Tesseract lang code) and timeout
# OCR_LANGUAGE=eng
# OCR_TIMEOUT_MS=30000
# Docling document conversion timeout (ms)
# DOCLING_TIMEOUT_MS=120000

# Auto-Watch (optional — auto-ingest when files change)
# Comma-separated: path|collection,path|collection
WATCH_PATHS=
WATCH_DEBOUNCE_MS=3000
# Glob patterns to exclude from watch (comma-separated, e.g., "*.tmp,*.log")
# WATCH_EXCLUDE_PATTERNS=
# Max concurrent file ingestions from watcher
# WATCH_MAX_CONCURRENT=5
# Max queued watcher events before dropping oldest
# WATCH_MAX_QUEUE=1000

# Defaults
DEFAULT_COLLECTION=default
CHUNK_MIN_TOKENS=100
CHUNK_MAX_TOKENS=1024
CHUNK_TARGET_TOKENS=512
QUERY_TOP_K=10
QUERY_TOKEN_BUDGET=4000

# Service startup timeouts (ms) — increase for slow hardware or large models
# THREADCLAW_MODEL_TIMEOUT=180000
# THREADCLAW_API_TIMEOUT=30000
# THREADCLAW_STOP_TIMEOUT=20000

# Optional API key — if set, all endpoints except /health require Authorization: Bearer <key>
# THREADCLAW_API_KEY=

# For advanced settings (source adapters, Evidence OS, audio transcription),
# see .env.advanced.example

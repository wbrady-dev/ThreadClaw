{
  "name": "clawcore",
  "version": "0.3.0",
  "description": "CRAM Architecture — Retrieval, Knowledge Graphs, Awareness, Evidence State, and Context Compilation for OpenClaw",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli/clawcore.ts",
    "typecheck": "tsc --noEmit",
    "test": "cd memory-engine && npx vitest run && cd .. && npx vitest run --config vitest.config.ts",
    "test:src": "npx vitest run --config vitest.config.ts",
    "test:tui": "npx tsc --outDir .tui-test-build --module nodenext --moduleResolution nodenext --target es2022 --skipLibCheck --allowImportingTsExtensions true --rewriteRelativeImportExtensions true test/tui/run.ts && node .tui-test-build/test/tui/run.js",
    "test:stress": "cd memory-engine && npx vitest run test/cram-stress.test.ts",
    "smoke": "node bin/clawcore.mjs --version",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "bin": {
    "clawcore": "./bin/clawcore.mjs"
  },
  "author": "Wesley Brady",
  "contributors": [
    "Nico Bailon <nicobailon> (lossless-claw / Martian Engineering)"
  ],
  "license": "MIT",
  "keywords": [
    "cram",
    "rag",
    "dag",
    "retrieval",
    "memory",
    "embeddings",
    "knowledge-base",
    "openclaw",
    "mcp",
    "sqlite"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "@notionhq/client": "^5.13.0",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "googleapis": "^171.4.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "jsdom": "^29.0.0",
    "mailparser": "^3.9.4",
    "mammoth": "^1.12.0",
    "ora": "^9.3.0",
    "pdfjs-dist": "^5.4.296",
    "pino": "^10.3.1",
    "prompts": "^2.4.2",
    "react": "^19.2.4",
    "sqlite-vec": "^0.1.7-alpha.2",
    "uuid": "^13.0.0",
    "xxhash-wasm": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
